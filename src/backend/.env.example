HELMOS_ENV=local
HELMOS_LOG_LEVEL=INFO
HELMOS_API_PREFIX=/api/v1
HELMOS_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/helmos
HELMOS_REDIS_URL=redis://localhost:6379/0
HELMOS_S3_ENDPOINT_URL=http://localhost:9000
HELMOS_S3_BUCKET=helmos-artifacts
HELMOS_S3_ACCESS_KEY=minioadmin
HELMOS_S3_SECRET_KEY=minioadmin
HELMOS_LANGSMITH_ENABLED=false
HELMOS_LANGSMITH_API_KEY=
HELMOS_LANGSMITH_PROJECT=helmos-agentic-layer
HELMOS_LLM_GATEWAY_PROVIDER=litellm_proxy
HELMOS_LITELLM_PROXY_URL=http://localhost:4000
HELMOS_LITELLM_API_KEY=sk-helmos-dev
HELMOS_LITELLM_TIMEOUT_SECONDS=60
HELMOS_DEFAULT_MODEL=helmos-default
HELMOS_SUPERVISOR_MODEL=helmos-supervisor
HELMOS_VECTOR_DIMENSIONS=1536
HELMOS_ENABLE_APPROVALS=true
HELMOS_CORS_ALLOWED_ORIGINS=http://127.0.0.1:4210,http://localhost:4210,http://127.0.0.1:4200,http://localhost:4200
AUTH_SERVICE_SIGN_IN_URL=http://auth-service.localhost:46138/
