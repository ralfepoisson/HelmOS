{
  "agent_definitions": [
    {
      "key": "ideation",
      "name": "Ideation Agent",
      "version": "1.0.0",
      "description": "Transforms founder input into structured idea briefs.",
      "allowed_tools": ["retrieval"],
      "default_model": "helmos-default"
    },
    {
      "key": "research",
      "name": "Research Agent",
      "version": "1.0.0",
      "description": "Produces market and evidence summaries.",
      "allowed_tools": ["web_search", "retrieval"],
      "default_model": "helmos-research"
    },
    {
      "key": "roadmap",
      "name": "Roadmap Agent",
      "version": "1.0.0",
      "description": "Converts validated insight into roadmap proposals.",
      "allowed_tools": ["retrieval", "object_storage"],
      "default_model": "helmos-default"
    }
  ],
  "prompt_configs": [
    {
      "key": "ideation.default",
      "version": "1.0.0",
      "prompt_template": "Generate a founder-oriented idea brief from: {prompt}",
      "config_json": {
        "temperature": 0.2,
        "artifact_kind": "idea_brief",
        "artifact_title": "Idea Brief",
        "artifact_summary": "Structured synthesis of a founder's concept and early positioning.",
        "system_prompt": "You are the HelmOS Ideation Agent. Produce a concise founder-oriented idea brief with clear strategic framing.",
        "output_sections": [
          {
            "heading": "Opportunity",
            "template": "{prompt}"
          },
          {
            "heading": "Brief",
            "template": "{llm_output}"
          }
        ],
        "next_actions": [
          "Validate the founder assumptions",
          "Promote the strongest ideas into roadmap planning"
        ]
      }
    },
    {
      "key": "research.default",
      "version": "1.0.0",
      "prompt_template": "Create a research summary for: {prompt}",
      "config_json": {
        "temperature": 0.1,
        "artifact_kind": "research_summary",
        "artifact_title": "Research Summary"
      }
    },
    {
      "key": "roadmap.default",
      "version": "1.0.0",
      "prompt_template": "Create a phased roadmap for: {prompt}",
      "config_json": {
        "temperature": 0.2,
        "artifact_kind": "roadmap",
        "artifact_title": "Roadmap Proposal"
      }
    }
  ]
}
