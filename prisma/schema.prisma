model ProtoIdeaSource {
  id                           String                    @id @default(uuid()) @db.Uuid
  ownerUserId                  String                    @map("owner_user_id") @db.Uuid
  prospectingConfigurationId   String?                   @map("prospecting_configuration_id") @db.Uuid
  extractionPolicyId           String?                   @map("extraction_policy_id") @db.Uuid
  upstreamSourceRecordId       String                    @map("upstream_source_record_id") @db.VarChar(255)
  sourceKey                    String                    @map("source_key") @db.VarChar(512)
  sourceTitle                  String?                   @map("source_title") @db.VarChar(500)
  sourceUrl                    String?                   @map("source_url")
  sourceType                   String?                   @map("source_type") @db.VarChar(100)
  sourceCapturedAt             DateTime?                 @map("source_captured_at")
  sourcePayload                Json                      @map("source_payload")
  processingStatus             ProtoIdeaProcessingStatus @default(PENDING) @map("processing_status")
  processingStartedAt          DateTime?                 @map("processing_started_at")
  processingCompletedAt        DateTime?                 @map("processing_completed_at")
  processingFailedAt           DateTime?                 @map("processing_failed_at")
  attempts                     Int                       @default(0)
  latestGatewayRunId           String?                   @map("latest_gateway_run_id") @db.VarChar(255)
  extractionPolicySnapshot     Json?                     @map("extraction_policy_snapshot")
  lastErrorMessage             String?                   @map("last_error_message")
  lastErrorMeta                Json?                     @map("last_error_meta")
  rawLlmPayload                Json?                     @map("raw_llm_payload")
  parsedResponse               Json?                     @map("parsed_response")
  sourceSummary                String?                   @map("source_summary")
  overallSignalStrengthLabel   String?                   @map("overall_signal_strength_label") @db.VarChar(100)
  overallSignalStrengthTone    String?                   @map("overall_signal_strength_tone") @db.VarChar(100)
  overallSignalAgentConfidence String?                   @map("overall_signal_agent_confidence") @db.VarChar(100)
  overallSignalExplanation     String?                   @map("overall_signal_explanation")
  extractionNotes              String?                   @map("extraction_notes")
  deduplicationNotes           String?                   @map("deduplication_notes")
  createdAt                    DateTime                  @default(now()) @map("created_at")
  updatedAt                    DateTime                  @updatedAt @map("updated_at")
  ownerUser                    User                      @relation(fields: [ownerUserId], references: [id])
  prospectingConfiguration     ProspectingConfiguration? @relation(fields: [prospectingConfigurationId], references: [id])
  extractionPolicy             ProtoIdeaExtractionPolicy? @relation(fields: [extractionPolicyId], references: [id])
  protoIdeas                   ProtoIdea[]

  @@unique([ownerUserId, sourceKey])
  @@index([processingStatus, sourceCapturedAt, updatedAt])
  @@index([ownerUserId, processingStatus, sourceCapturedAt])
  @@index([prospectingConfigurationId, processingStatus])
  @@index([extractionPolicyId, processingStatus])
  @@map("proto_idea_sources")
}

model ProtoIdea {
  id                    String          @id @default(uuid()) @db.Uuid
  ownerUserId           String          @map("owner_user_id") @db.Uuid
  sourceId              String          @map("source_id") @db.Uuid
  title                 String          @db.VarChar(255)
  problemStatement      String          @map("problem_statement")
  targetCustomer        String          @map("target_customer")
  opportunityHypothesis String          @map("opportunity_hypothesis")
  whyItMatters          String          @map("why_it_matters")
  opportunityType       String          @map("opportunity_type") @db.VarChar(100)
  explicitSignals       Json            @default("[]") @map("explicit_signals")
  inferredSignals       Json            @default("[]") @map("inferred_signals")
  assumptions           Json            @default("[]")
  openQuestions         Json            @default("[]") @map("open_questions")
  statusLabel           String          @map("status_label") @db.VarChar(100)
  statusTone            String          @map("status_tone") @db.VarChar(100)
  agentConfidence       String          @map("agent_confidence") @db.VarChar(100)
  statusExplanation     String          @map("status_explanation")
  refinementStatus      IdeaRefinementProcessingStatus @default(PENDING) @map("refinement_status")
  refinementStartedAt   DateTime?       @map("refinement_started_at")
  refinementCompletedAt DateTime?       @map("refinement_completed_at")
  refinementFailedAt    DateTime?       @map("refinement_failed_at")
  refinementAttempts    Int             @default(0) @map("refinement_attempts")
  latestRefinementPolicyId String?      @map("latest_refinement_policy_id") @db.Uuid
  latestRefinementGatewayRunId String?  @map("latest_refinement_gateway_run_id") @db.VarChar(255)
  latestRefinementErrorMessage String?  @map("latest_refinement_error_message")
  latestRefinementErrorMeta Json?       @map("latest_refinement_error_meta")
  rawLlmPayload         Json?           @map("raw_llm_payload")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")
  ownerUser             User            @relation(fields: [ownerUserId], references: [id])
  source                ProtoIdeaSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  latestRefinementPolicy IdeaRefinementPolicy? @relation(fields: [latestRefinementPolicyId], references: [id])
  ideaCandidates        IdeaCandidate[]

  @@index([ownerUserId, createdAt])
  @@index([sourceId, createdAt])
  @@index([ownerUserId, refinementStatus, createdAt])
  @@index([latestRefinementPolicyId, refinementStatus])
  @@map("proto_ideas")
}

model IdeaCandidate {
  id                        String               @id @default(uuid()) @db.Uuid
  ownerUserId               String               @map("owner_user_id") @db.Uuid
  protoIdeaId               String               @map("proto_idea_id") @db.Uuid
  policyId                  String?              @map("policy_id") @db.Uuid
  problemStatement          String               @map("problem_statement")
  targetCustomer            String               @map("target_customer")
  valueProposition          String               @map("value_proposition")
  opportunityConcept        String               @map("opportunity_concept")
  differentiation           String
  assumptions               Json                 @default("[]")
  openQuestions             Json                 @default("[]") @map("open_questions")
  improvementSummary        String               @map("improvement_summary")
  keyChanges                Json                 @default("[]") @map("key_changes")
  appliedReasoningSummary   String               @map("applied_reasoning_summary")
  appliedConceptualToolIds  Json                 @default("[]") @map("applied_conceptual_tool_ids")
  qualityCheckCoherence     String               @map("quality_check_coherence")
  qualityCheckGaps          Json                 @default("[]") @map("quality_check_gaps")
  qualityCheckRisks         Json                 @default("[]") @map("quality_check_risks")
  statusLabel               String               @map("status_label") @db.VarChar(100)
  statusTone                String               @map("status_tone") @db.VarChar(100)
  agentConfidence           String               @map("agent_confidence") @db.VarChar(100)
  statusExplanation         String               @map("status_explanation")
  refinementIteration       Int                  @default(1) @map("refinement_iteration")
  deduplicationFingerprint  String?              @map("deduplication_fingerprint") @db.VarChar(1000)
  rawLlmPayload             Json?                @map("raw_llm_payload")
  createdAt                 DateTime             @default(now()) @map("created_at")
  updatedAt                 DateTime             @updatedAt @map("updated_at")
  ownerUser                 User                 @relation(fields: [ownerUserId], references: [id])
  protoIdea                 ProtoIdea            @relation(fields: [protoIdeaId], references: [id], onDelete: Cascade)
