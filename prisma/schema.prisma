  reviewedByUser     User?                       @relation("SupportRecommendationReviewedBy", fields: [reviewedByUserId], references: [id])

  @@index([ticketId, createdAt])
  @@index([status, updatedAt])
  @@index([reviewedByUserId, reviewedAt])
  @@map("support_recommendations")
}

model ActivityLog {
