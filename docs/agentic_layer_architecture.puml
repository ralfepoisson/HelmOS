@startuml
package "Agent Experience Layer" {
  [Marketing Website]
  [Angular UI]
  [Angular Dev Proxy]
  [Auth Callback & Route Guards]
  [Root Idea Selection Redirect]
  [My Business Ideas Page]
  [Idea Foundry Shell]
  [Idea Foundry Overview Board]
  [Prospecting Configuration Screen]
  [Proto-Idea Extraction Screen]
  [Value Proposition Screen]
  [Node Control Plane API]
  [Prospecting Configuration API]
  [Proto-Idea Extraction API]
  [Gateway Registry Preflight]
  [Agent Gateway API (FastAPI)]
  [Agent Admin Screen]
  [Agent Test Admin Screen]
  [Logs Admin Screen]
}

package "Identity & Access Layer" {
  [Life2 Auth Service]
  [JWT Session Bootstrap]
  [RBAC Policy]
}

package "Orchestration Layer (LangGraph)" {
  [Supervisor Agent]
  [Planner / Router]
  [Workflow Graph Engine]
  [State & Checkpoint Manager]
  [Policy / Guardrail Service]
}

package "Specialist Agents" {
  [Ideation Agent]
  [Value Proposition Agent]
  [Research Agent]
  [Roadmap Agent]
  [Architecture Agent]
  [Artifact Agent]
  [Testing Agent]
}

package "Agent Testing Framework" {
  [Test Harness Service]
  [Agent Test Execution Service]
  [Agent Test Queue Worker]
  [Scenario Driver]
  [Fixture Registry Sync]
  [Fixture Repository]
  [Rubric Registry]
  [Comparison Engine]
  [Report Renderer]
  [Run Detail Evidence API]
}

package "Deterministic Services" {
  [Prospecting Runtime Scheduler]
  [Prospecting Execution Service]
  [Proto-Idea Extraction Service]
  [Proto-Idea Stage Runner]
  [Template Renderer]
  [Rules Engine]
  [Output Normaliser]
  [Document Export Service]
}

package "Tool Layer" {
  [Tool Registry]
  [Web Search Adapter]
  [Retrieval Adapter]
  [Storage Adapter]
  [External Integrations]
}

package "Data Layer" {
  [Gateway Runtime PostgreSQL]
  [Shared Registry PostgreSQL]
  [pgvector]
  [Redis]
  [Object Storage]
}

package "AgentOps & Observability" {
  [LangSmith]
  [OpenTelemetry]
  [Audit Logs]
  [Agent Registry]
  [Prompt Registry]
}

package "AWS Production Deployment" {
  [Route 53]
  [ACM]
  [CloudFront]
  [S3 Website Bucket]
  [Marketing Site Files]
  [Strategy App Files (/app)]
  [Application Load Balancer]
  [ECS Fargate - Node API]
  [ECS Fargate - Agent Gateway]
  [ECS Fargate - LiteLLM]
  [ECR]
  [RDS PostgreSQL]
  [ElastiCache Redis]
  [S3 Artifact Bucket]
}

[Marketing Website] --> [CloudFront] : helm-os.ai and www.helm-os.ai
[Angular UI] --> [Angular Dev Proxy] : local /api and /api/v1
[Angular UI] --> [Auth Callback & Route Guards] : restore session, route gating
[Angular UI] --> [Root Idea Selection Redirect] : decide / entry based on saved ideas
[Root Idea Selection Redirect] --> [Node Control Plane API] : list business ideas for current user
[Angular UI] --> [My Business Ideas Page]
[My Business Ideas Page] --> [Node Control Plane API] : list business ideas and select active workspace
[Angular UI] --> [Idea Foundry Shell]
[Idea Foundry Shell] --> [Idea Foundry Overview Board] : pipeline navigation and overview stages
[Idea Foundry Shell] --> [Prospecting Configuration Screen] : prospecting submenu and operator controls
[Idea Foundry Shell] --> [Proto-Idea Extraction Screen] : admin policy controls and agent run trigger
[Prospecting Configuration Screen] --> [Prospecting Configuration API] : load config, trigger agent optimization cycles, and run prospecting execution
[Proto-Idea Extraction Screen] --> [Proto-Idea Extraction API] : load policy, save policy, and run Proto-Idea Agent
[Idea Foundry Overview Board] --> [Prospecting Configuration API] : read persisted source records or render empty states
[Prospecting Configuration API] --> [Node Control Plane API] : authenticated control-plane request path
[Proto-Idea Extraction API] --> [Node Control Plane API] : authenticated admin control-plane request path
[Prospecting Configuration API] --> [Gateway Registry Preflight] : verify requested agent is registered before review runs
[Proto-Idea Extraction API] --> [Gateway Registry Preflight] : verify requested agent is registered before extraction runs
[Node Control Plane API] --> [Audit Logs] : persist gateway request traces, raw LLM output, and parsed JSON output for agent-driven workflows
[Node Control Plane API] --> [Prospecting Runtime Scheduler] : start hourly prospecting runtime loop
[Node Control Plane API] --> [Prospecting Execution Service] : execute latest saved prospecting strategy and close the review-feedback loop
[Node Control Plane API] --> [Proto-Idea Extraction Service] : load persisted proto-ideas for pipeline reads
[Prospecting Runtime Scheduler] --> [Prospecting Execution Service] : run hourly prospecting optimization cycles
[Prospecting Runtime Scheduler] ..> [Prospecting Configuration API] : persisted next run stays aligned to enforced hourly cadence
[Proto-Idea Stage Runner] --> [Proto-Idea Extraction Service] : run a controlled extraction pass over pending sources
[Gateway Registry Preflight] --> [Agent Gateway API (FastAPI)] : fetch runtime registry snapshot
[Angular UI] --> [Node Control Plane API] : load workspace unlock state and available strategy tools
[Angular UI] --> [Value Proposition Screen]
[Value Proposition Screen] --> [Node Control Plane API] : load value proposition canvas and persist chat-driven updates
[Auth Callback & Route Guards] --> [Life2 Auth Service] : browser sign-in with applicationId and redirect
[Node Control Plane API] --> [Life2 Auth Service] : optional compatibility redirect using applicationId
[Auth Callback & Route Guards] --> [Angular UI] : local sign-out clears stored JWT and routes to signed-out screen
[Auth Callback & Route Guards] --> [JWT Session Bootstrap] : capture hash-route token before app bootstrap
[Angular Dev Proxy] --> [Node Control Plane API] : /api
[Angular Dev Proxy] --> [Agent Gateway API (FastAPI)] : /api/v1
[Angular UI] --> [Agent Admin Screen]
[Agent Admin Screen] --> [Node Control Plane API] : create/update agent registry
[Angular UI] --> [Agent Test Admin Screen]
[Agent Test Admin Screen] --> [Agent Gateway API (FastAPI)] : fixture discovery, run control, and review data
[Agent Test Admin Screen] --> [Run Detail Evidence API] : transcript turns, score evidence, and snapshot artifacts
[Angular UI] --> [Logs Admin Screen]
[Logs Admin Screen] --> [Node Control Plane API] : search backend logs, filter by scope, timed refresh
[Node Control Plane API] --> [RBAC Policy] : verify JWT, derive user context, enforce access
[Node Control Plane API] --> [Shared Registry PostgreSQL] : persist workspace feature unlocks and stage availability
[RBAC Policy] --> [Shared Registry PostgreSQL] : upsert local user, tenant link, app role
[Node Control Plane API] --> [Agent Gateway API (FastAPI)] : runtime snapshot
[Node Control Plane API] --> [Agent Registry] : create/update definitions
[Node Control Plane API] --> [Prompt Registry] : create/update active prompts
[Agent Gateway API (FastAPI)] --> [Supervisor Agent]
[Agent Gateway API (FastAPI)] --> [Audit Logs] : persist run audit events and normalized outputs with raw LLM traces
[Supervisor Agent] --> [Planner / Router]
[Planner / Router] --> [Workflow Graph Engine]
[Workflow Graph Engine] --> [State & Checkpoint Manager]
[Workflow Graph Engine] --> [Policy / Guardrail Service]

[Workflow Graph Engine] --> [Ideation Agent]
[Workflow Graph Engine] --> [Value Proposition Agent]
[Workflow Graph Engine] --> [Research Agent]
[Workflow Graph Engine] --> [Roadmap Agent]
[Workflow Graph Engine] --> [Architecture Agent]
[Workflow Graph Engine] --> [Artifact Agent]
[Test Harness Service] --> [Scenario Driver]
[Test Harness Service] --> [Agent Test Execution Service]
[Agent Test Queue Worker] --> [Agent Test Execution Service]
[Agent Test Execution Service] --> [Scenario Driver]
[Agent Test Execution Service] --> [Fixture Repository]
[Fixture Registry Sync] --> [Fixture Repository]
[Agent Test Execution Service] --> [Rubric Registry]
[Agent Test Execution Service] --> [Report Renderer]
[Run Detail Evidence API] --> [Agent Gateway API (FastAPI)] : admin run detail responses
[Run Detail Evidence API] --> [Gateway Runtime PostgreSQL] : read run, transcript, annotation, and score records
[Agent Test Execution Service] --> [Ideation Agent]
[Agent Test Execution Service] --> [Value Proposition Agent]
[Test Harness Service] --> [Fixture Repository]
[Agent Gateway API (FastAPI)] --> [Fixture Registry Sync] : sync docs-authored fixtures into runtime DB
[Test Harness Service] --> [Rubric Registry]
[Test Harness Service] --> [Testing Agent]
[Test Harness Service] --> [Report Renderer]
[Test Harness Service] --> [Comparison Engine]
[Test Harness Service] --> [Agent Gateway API (FastAPI)] : admin-driven execution and evaluation
[Agent Test Execution Service] --> [Agent Gateway API (FastAPI)] : production-path specialist execution
[Agent Gateway API (FastAPI)] --> [Agent Test Queue Worker] : lifespan background worker
[Agent Gateway API (FastAPI)] --> [Test Harness Service] : admin-driven evaluation flows

[Workflow Graph Engine] --> [Template Renderer]
[Workflow Graph Engine] --> [Rules Engine]
[Workflow Graph Engine] --> [Output Normaliser]
[Workflow Graph Engine] --> [Document Export Service]
[Prospecting Execution Service] --> [Agent Gateway API (FastAPI)] : invoke shared web-search tool
[Prospecting Execution Service] --> [Shared Registry PostgreSQL] : store normalized result records for the next prospecting review cycle
[Proto-Idea Extraction Service] --> [Agent Gateway API (FastAPI)] : invoke Proto-Idea Agent for one claimed source at a time
[Proto-Idea Extraction Service] --> [Shared Registry PostgreSQL] : store source processing state and extracted proto-ideas

[Ideation Agent] --> [Tool Registry]
[Value Proposition Agent] --> [Tool Registry]
[Research Agent] --> [Tool Registry]
[Roadmap Agent] --> [Tool Registry]

[Tool Registry] --> [Web Search Adapter]
[Tool Registry] --> [Retrieval Adapter]
[Tool Registry] --> [Storage Adapter]
[Tool Registry] --> [External Integrations]

[Agent Gateway API (FastAPI)] --> [Shared Registry PostgreSQL] : read agent definitions and prompt configs
[State & Checkpoint Manager] --> [Gateway Runtime PostgreSQL]
[Retrieval Adapter] --> [pgvector]
[Workflow Graph Engine] --> [Redis]
[Storage Adapter] --> [Object Storage]

[Workflow Graph Engine] --> [LangSmith]
[Workflow Graph Engine] --> [OpenTelemetry]
[Workflow Graph Engine] --> [Audit Logs]
[Workflow Graph Engine] --> [Agent Registry]
[Workflow Graph Engine] --> [Prompt Registry]
[Test Harness Service] --> [Audit Logs]
[Test Harness Service] --> [Agent Registry]
[Test Harness Service] --> [Prompt Registry]
[Test Harness Service] --> [Object Storage]
[Test Harness Service] --> [Gateway Runtime PostgreSQL]
[Fixture Registry Sync] --> [Gateway Runtime PostgreSQL]

[Route 53] --> [ACM]
[Route 53] --> [CloudFront]
[CloudFront] --> [S3 Website Bucket]
[S3 Website Bucket] --> [Marketing Site Files]
[S3 Website Bucket] --> [Strategy App Files (/app)]
[CloudFront] --> [Application Load Balancer] : /api and /api/v1
[Application Load Balancer] --> [ECS Fargate - Node API]
[Application Load Balancer] --> [ECS Fargate - Agent Gateway]
[ECS Fargate - Node API] --> [ECS Fargate - Agent Gateway]
[ECS Fargate - Agent Gateway] --> [ECS Fargate - LiteLLM]
[ECS Fargate - Node API] --> [RDS PostgreSQL]
[ECS Fargate - Agent Gateway] --> [RDS PostgreSQL]
[ECS Fargate - Agent Gateway] --> [ElastiCache Redis]
[ECS Fargate - Agent Gateway] --> [S3 Artifact Bucket]
[ECR] --> [ECS Fargate - Node API]
[ECR] --> [ECS Fargate - Agent Gateway]
[ECR] --> [ECS Fargate - LiteLLM]

@enduml
